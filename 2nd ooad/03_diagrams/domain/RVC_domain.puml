@startuml RVC_domain
!theme plain
skinparam shadowing false
skinparam classAttributeIconSize 0
skinparam classIconSize 0
skinparam linetype polyline
skinparam nodesep 28
skinparam ranksep 32
skinparam ArrowThickness 1
skinparam directionStyle none

title Roomba RVC — Domain model\n(SRS v0.7.2: travelToggle, back sensor, dust maneuver)

skinparam class<<domain>> {
  BackgroundColor #FFFFFF
  BorderColor #3A6EA5
}
skinparam class<<external>> {
  BackgroundColor #ECECEC
  BorderColor #707070
}
skinparam package {
  BackgroundColor #D4E8F8
  BorderThickness 0
  FontColor transparent
}

hide circle
hide stereotype

legend top left
  |= |= |
  | <#D4E8F8> | Inside software (SRS §3.2) |
  | <#ECECEC> | Outside software |
endlegend

class "Home user / Scheduler" as User <<external>>
class "Direct obstacle sensors\n(front, left, back)" as ObsHW <<external>>
class "Dust sensor" as DustHW <<external>>
class "Wheel motors\n(left, right)" as MotionHW <<external>>
class "Cleaning hardware" as CleanHW <<external>>

package " " as InsideSW {

  class AutomaticCleaningSession <<domain>> {
    sessionActive : Boolean
    sessionSource : SessionSource
  }

  class ObstaclePerceptionContext <<domain>> {
    frontObstacle : Boolean
    leftObstacle : Boolean
    backObstacle : Boolean
    rightObstacleInferred : Boolean
    rightProbeStatus : ProbeStatus
    lastUpdateTime : TimeStamp
  }

  class NavigationAndEscapeCoordinator <<domain>> {
    motionState : MotionState
    travelToggle : TravelToggle
    backupDistanceRemaining : Distance
  }

  class SurfaceCleaningController <<domain>> {
    cleaningMode : CleaningMode
    powerLevel : PowerLevel
    dustSignal : DustSignal
  }
}

User "0..*" -down- "1" AutomaticCleaningSession : StartSession /\nStopSession

ObsHW "3" -down- "1" ObstaclePerceptionContext : ObstacleStateChanged\n(front/left/back direct)

DustHW "1" -down- "1" SurfaceCleaningController : DustSignalUpdated

AutomaticCleaningSession "1" -right- "1" NavigationAndEscapeCoordinator : notifies session state\n(initial travelToggle=Forward)
AutomaticCleaningSession "1" -left- "1" SurfaceCleaningController : notifies session state\n(initial cleaningMode=Normal)

ObstaclePerceptionContext "1" -down- "1" NavigationAndEscapeCoordinator : FusedObstacleSnapshot /\nRequestRightSideProbe

NavigationAndEscapeCoordinator "1" -down- "1" SurfaceCleaningController : SuspendCleaningForManeuver\nResumeCleaningAfterManeuver\nStartBoostCleaning / EndBoostCleaning

NavigationAndEscapeCoordinator "1" -down- "2" MotionHW : MotionCommand\n(forward/reverse/turn/probe/spin540)
SurfaceCleaningController "1" -down- "1" CleanHW : CleaningCommand\n(normal/boost/suspend)

note bottom of ObstaclePerceptionContext
  **FusedObstacleSnapshot** (message payload,
  OBJ3-FR-3): direct front/left/back (when
  applicable) plus right-side probe result;
  back ignored during dust maneuver; back
  not leading sector during surrounded-escape
  reverse (still used for probe if toggled
  Backward)
end note

note bottom of NavigationAndEscapeCoordinator
  **travelToggle** swaps leading travel edge:
  Forward = front leads; Backward = back leads.
  Toggled on dust-maneuver completion only.
  **ToggleTravelDirection** (internal)
end note

note right of ObsHW
  No dedicated right-side sensor.
  Right-side probe uses **front** sensor when
  travelToggle=Forward, **back** sensor when
  travelToggle=Backward.
end note

@enduml
