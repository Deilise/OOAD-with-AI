@startuml UC05_sequence
!theme plain
hide footbox
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam BoxPadding 10
autonumber

title UC-05 — Escape when surrounded\n(sequence diagram)

actor "Home user\n(beneficiary)" as User
participant "Direct front / left / back\nobstacle sensors" as Obs
box "Roomba RVC control software\n(inside the SSD black box)" #E8F4FF
  participant "perception:\nObstaclePerceptionContext" as Perception
  participant "navigation:\nNavigationAndEscapeCoordinator" as Nav
  participant "cleaning:\nSurfaceCleaningController" as Clean
end box
participant "Wheel motors\n(left, right)" as Motors
participant "Cleaning hardware" as CleanHW

note over User, Clean : surrounded = body-fixed front ∧ left ∧ right\n(probe uses front if Forward toggle, back if Backward)\nescape reverse ≠ toggled cruise; travelToggle preserved

alt [typical Forward toggle]
  Obs -> Perception : ObstacleStateChanged(front=blocked, left=blocked)
  Perception -> Nav : RequestRightSideProbe(reason=surroundedCheck)
  Nav -> Clean : SuspendCleaningForManeuver()
  Clean -> CleanHW : CleaningCommand(suspend)
  Nav -> Motors : MotionCommand(action=probeRightSide)
  Obs -> Perception : ObstacleStateChanged(probePose=right, front=blocked)
  Perception -> Nav : FusedObstacleSnapshot(surrounded=true)
  Nav -> Motors : MotionCommand(action=restoreHeading)
  Nav -> Motors : MotionCommand(reverseEscapeSegment)
  note over Nav, Motors : back sensor not leading sector during escape reverse
  Obs -> Perception : ObstacleStateChanged(leadingSector=safe)
  Perception -> Nav : FusedObstacleSnapshot(leadingSectorSafe)
  Nav -> Motors : MotionCommand(forward)
  Nav -> Clean : ResumeCleaningAfterManeuver()
  Clean -> CleanHW : CleaningCommand(normal)
  note over Nav, Motors : next: UC-02; travelToggle unchanged
else [typical Backward toggle]
  Obs -> Perception : ObstacleStateChanged(front=blocked, left=blocked)
  Perception -> Nav : RequestRightSideProbe(reason=surroundedCheck)
  Nav -> Clean : SuspendCleaningForManeuver()
  Clean -> CleanHW : CleaningCommand(suspend)
  Nav -> Motors : MotionCommand(action=probeRightSide)
  Obs -> Perception : ObstacleStateChanged(probePose=right, back=blocked)
  Perception -> Nav : FusedObstacleSnapshot(surrounded=true)
  Nav -> Motors : MotionCommand(action=restoreHeading)
  Nav -> Motors : MotionCommand(reverseEscapeSegment)
  Obs -> Perception : ObstacleStateChanged(leadingSector=safe)
  Perception -> Nav : FusedObstacleSnapshot(leadingSectorSafe)
  Nav -> Motors : MotionCommand(reverse)
  Nav -> Clean : ResumeCleaningAfterManeuver()
  Clean -> CleanHW : CleaningCommand(normal)
  note over Nav, Motors : next: UC-02; travelToggle unchanged
else [A1 repeated surrounded]
  loop [until leading sector clears]
    Obs -> Perception : ObstacleStateChanged(surrounded=true)
    Perception -> Nav : FusedObstacleSnapshot(surrounded=true)
    Nav -> Motors : MotionCommand(reverseEscapeSegment)
    Obs -> Perception : ObstacleStateChanged(leadingSector=stillBlocked)
    Perception -> Nav : FusedObstacleSnapshot(leadingSectorBlocked)
  end
else [E1 escape cannot complete]
  Obs -> Perception : ObstacleStateChanged(surrounded=true, escapePath=invalid)
  Perception -> Nav : FusedObstacleSnapshot(invalid)
  Nav -> Motors : MotionCommand(stopOrFallbackTBD)
  note over Perception, Nav : next: UC-08 (TBD)
end

@enduml
