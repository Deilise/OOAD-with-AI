@startuml UC08_sequence
!theme plain
hide footbox
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam BoxPadding 10
autonumber

title UC-08 - Handle missing / invalid / stale obstacle or probe data\n(sequence diagram)

actor "Home user" as User
participant "Direct front / left\nobstacle sensors" as Obs
box "Roomba RVC control software\n(inside the SSD black box)" #E8F4FF
  participant "session:\nAutomaticCleaningSession" as Session
  participant "perception:\nObstaclePerceptionContext" as Perception
  participant "navigation:\nNavigationAndEscapeCoordinator" as Nav
  participant "cleaning:\nSurfaceCleaningController" as Clean
end box
participant "Wheel motors\n(left, right)" as Motors
participant "Cleaning hardware" as CleanHW

alt [typical full fault]
  Obs -> Perception : ObstacleStateChanged(frontOrLeft=invalidOrStale)
  Perception -> Nav : FusedObstacleSnapshot(invalid)
  Nav -> Motors : MotionCommand(stop)
  Nav -> Clean : SuspendCleaningForManeuver()
  Clean -> CleanHW : CleaningCommand(suspend)
else [A1 partial staleness]
  Obs -> Perception : ObstacleStateChanged(frontOrLeft=partialStale)
  Perception -> Nav : FusedObstacleSnapshot(partialStale)
  Nav -> Motors : MotionCommand(gradualOrPartialStopTBD)
else [probe invalid or timed out]
  Obs -> Perception : ObstacleStateChanged(probePose=right, front=invalidOrTimeout)
  Perception -> Nav : FusedObstacleSnapshot(invalid)
  Nav -> Motors : MotionCommand(stopOrFallbackTBD)
  Nav -> Clean : SuspendCleaningForManeuver()
  Clean -> CleanHW : CleaningCommand(suspend)
end

alt [typical recovery]
  Obs -> Perception : ObstacleStateChanged(frontAndLeft=recovered)
  Obs -> Perception : ObstacleStateChanged(probePose=right, front=validWhenRequired)
  Perception -> Nav : FusedObstacleSnapshot(valid)
  note over Perception, Nav : recovery before UC-02: TBD
else [E1 never recovers]
  note over User : user resets or moves robot
  User -> Session : requestServiceOrReset()
  note over User, Session : hardware / service TBD
end

@enduml
